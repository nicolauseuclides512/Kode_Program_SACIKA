PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://sacika_app:YOUR_PASSWORD@localhost:5432/sacika_db
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

JWT_SECRET=replace_with_a_long_random_secret_at_least_32_characters
JWT_EXPIRES_IN=1d
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_BLOCK_MS=900000
CORS_ALLOWED_ORIGINS=http://localhost:5173
FORECAST_WORKER_URL=http://localhost:5000

ADMIN_NAME=Administrator SACIKA
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_password

# Optional default paths for product bootstrap
PRODUCT_BOOTSTRAP_REPORT=product-bootstrap-report.json
